{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(go:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(curl:*)",
      "Bash(claude mcp:*)",
      "Bash(for:*)",
      "Read(//Users/grippado/**)",
      "Read(//private/tmp/**)",
      "Bash(grep -v \"\\\\.go$\")",
      "Bash(grep \"\\\\.go$\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 0 > /tmp/claude-brain-counter"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "count=$(cat /tmp/claude-brain-counter 2>/dev/null || echo 0); echo $((count + 1)) > /tmp/claude-brain-counter",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "count=$(cat /tmp/claude-brain-counter 2>/dev/null || echo 0); if [ \"$count\" -ge 5 ]; then echo '{\"systemMessage\":\"LEMBRETE: Esta sessao teve trabalho substancial. Sugira ao usuario rodar /sync para atualizar ClickUp + Brain + Memory de uma vez. Comandos avulsos: /clickup status (ver board), /brain (só vault).\"}'; fi",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
